# ─── Copy this file to .env and fill in your values ─────────────────────────
# For LOCAL development: use a Neon connection string (see neon.tech)
# For VERCEL: set these in Vercel Dashboard → Project Settings → Environment Variables

# ─── Database (PostgreSQL — get from neon.tech) ───────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── NextAuth v5 ─────────────────────────────────────────────────────────────
# For local dev:
NEXTAUTH_URL="http://localhost:3000"
# For Vercel: set to your live URL, e.g. https://ironpeak.vercel.app

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="your-random-32-character-secret-here"

AUTH_TRUST_HOST=true

# ─── Stripe (optional — for real payments) ───────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
